# ═══════════════════════════════════════════════════════════════
# PixelScribe / TextClear — .gitignore
# ═══════════════════════════════════════════════════════════════

# ── Python ────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo

# ── Virtual Environments ─────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── SQLite databases ─────────────────────────────────────────
*.db
*.db-journal
*.db-wal
*.db-shm

# ── Runtime data (uploads, results, ephemeral state) ─────────
data/uploads/*
data/results/*
uploads/*
results/*
!data/uploads/.gitkeep
!data/results/.gitkeep
!uploads/.gitkeep
!results/.gitkeep

# ── ML model weights (large binaries — use Git LFS or DVC) ──
models/*.onnx
models/*.pt
models/*.pth
models/*.bin
models/*.safetensors

# ── IDE / Editor ──────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── OS-specific ───────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# ── Distribution / Build ─────────────────────────────────────
dist/
build/
*.egg-info/
*.egg

# ── Logs ──────────────────────────────────────────────────────
*.log
logs/

# ── Docker runtime ────────────────────────────────────────────
docker-compose.override.yml

# ── Misc ──────────────────────────────────────────────────────
.env
.env.local
.env.*.local
*.bak
*.tmp

# ── Frontend & Capacitor ──────────────────────────────────────
node_modules/
ios/
android/
